generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  ID_User  String    @id @default(uuid())
  Nama     String
  Email    String    @unique
  Password String
  Peran    String
  Pesanan  Pesanan[]
  Produk   Produk[]
}

model Produk {
  ID_Produk      String           @id @default(uuid())
  ID_User_Petani String
  Nama_Produk    String
  Kategori       String
  Stok           Int
  Harga          Float
  Detail_Pesanan Detail_Pesanan[]
  Petani         User             @relation(fields: [ID_User_Petani], references: [ID_User], onDelete: Cascade)
}

model Pesanan {
  ID_Pesanan      String           @id @default(uuid())
  ID_User_Pembeli String
  Tanggal_Pesan   DateTime         @default(now())
  Status_Pesanan  String
  Total_Harga     Float
  Detail_Pesanan  Detail_Pesanan[]
  Pengiriman      Pengiriman[]
  Pembeli         User             @relation(fields: [ID_User_Pembeli], references: [ID_User], onDelete: Cascade)
}

model Detail_Pesanan {
  ID_Detail   String  @id @default(uuid())
  ID_Pesanan  String
  ID_Produk   String
  Jumlah_Beli Int
  Subtotal    Float
  Pesanan     Pesanan @relation(fields: [ID_Pesanan], references: [ID_Pesanan], onDelete: Cascade)
  Produk      Produk  @relation(fields: [ID_Produk], references: [ID_Produk], onDelete: Cascade)
}

model Pengiriman {
  ID_Pengiriman   String            @id @default(uuid())
  ID_Pesanan      String
  Kurir           String
  Resi            String            @unique
  Estimasi_Tiba   DateTime
  Status_Kirim    String
  BlockchainBlock BlockchainBlock[]
  Pesanan         Pesanan           @relation(fields: [ID_Pesanan], references: [ID_Pesanan], onDelete: Cascade)
}

model BlockchainBlock {
  ID_Block      String     @id @default(uuid())
  Index         Int
  Tanggal       DateTime   @default(now())
  ID_Pengiriman String
  Data          String
  Prev_Hash     String
  Hash          String
  Pengiriman    Pengiriman @relation(fields: [ID_Pengiriman], references: [ID_Pengiriman], onDelete: Cascade)
}
