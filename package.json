{
  "name": "saltchain-optima",
  "version": "1.0.0",
  "description": "Transparansi Distribusi Garam dari Petani hingga Industri",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "npx prisma generate",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev --name init",
    "prisma:seed": "node prisma/seed.js",
    "prisma:push": "npx prisma db push"
  },
  "keywords": [
    "blockchain",
    "salt",
    "supply-chain",
    "express",
    "prisma"
  ],
  "author": "SaltChain Team",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^5.14.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
